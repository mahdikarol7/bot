# Telegram Bot Token (required) — get from @BotFather
BOT_TOKEN=

# Admin Telegram user IDs, comma-separated (required)
# Users with these IDs can access admin commands
ADMIN_IDS=

# Data directory (default: ./data)
DATA_DIR=./data

# Max concurrent downloads (default: 3)
MAX_CONCURRENT_DOWNLOADS=3

# Max file size in MB for downloads (default: 150)
MAX_FILE_SIZE_MB=150

# Download timeout in seconds (default: 120)
DOWNLOAD_TIMEOUT_SEC=120

# Max downloads per user within the rate limit window (default: 5)
RATE_LIMIT_MAX=5

# Rate limit window in milliseconds (default: 3600000 = 1 hour)
RATE_LIMIT_WINDOW_MS=3600000

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# Default video quality: 360, 480, 720, or 1080 (default: 720)
DEFAULT_QUALITY=720

# Smart Cache: max cache size in GB (default: 0.5 = 500MB)
CACHE_MAX_SIZE_GB=0.5

# Smart Cache: expire cached files after N days without access (default: 7)
CACHE_EXPIRE_DAYS=7

# Smart Cache: cache directory relative to DATA_DIR (default: cache)
CACHE_DIR=cache

# HTTP/SOCKS proxy (optional, auto-detected from system on Windows)
# Set this if the bot can't reach Telegram directly
# HTTPS_PROXY=http://127.0.0.1:10808
